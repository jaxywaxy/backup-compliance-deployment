# Bicep Drift Ignore Patterns for backup-compliance-deployment
#
# Patterns that should not be reported as drift.

ignore:
  # System-managed resources — auto-created by Azure
  - resource_type: "Microsoft.Network/networkWatchers"
    reason: "Azure automatically creates network watchers in each region"

  - resource_type: "Microsoft.OperationalInsights/workspaces"
    reason: "Default Log Analytics workspace created by Azure monitoring"

  # Landing Zone infrastructure — managed separately from this Bicep template
  - resource_type: "Microsoft.Network/virtualNetworks"
    reason: "VNets are part of Landing Zone pattern, managed separately"

  - resource_type: "Microsoft.Network/virtualNetworks/*"
    reason: "VNets and their resources are part of Landing Zone infrastructure"

  # Auto-managed by Azure services
  - resource_type: "Microsoft.Compute/disks"
    reason: "OS and data disks are auto-created and managed by VMs"

  - resource_type: "Microsoft.Compute/virtualMachines/extensions"
    reason: "VM extensions are auto-managed by the VM parent resource"

  # Child resources with unresolvable parameter names (cannot deploy without runtime parameter resolution)
  - resource_type: "Microsoft.RecoveryServices/vaults/replicationFabrics"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/replicationFabrics/replicationProtectionContainers"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/replicationFabrics/replicationProtectionContainers/replicationProtectionContainerMappings"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/replicationPolicies"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/backupstorageconfig"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/backupFabrics/protectionContainers"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/backupFabrics/protectionContainers/protectedItems"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/backupPolicies"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/backupconfig"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/replicationAlertSettings"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.Network/privateEndpoints/privateDnsZoneGroups"
    reason: "Child resource with unresolvable parameter expressions in name"

  # Complex Bicep expressions that resolve at deployment time
  - resource_type: "Microsoft.RecoveryServices/vaults"
    drift_type: "*tags*"
    reason: "Tags from union(createObject(...)) expressions resolve correctly at deployment time with computed and parameter values"
